# =============================
# Node.js 特定忽略项
# =============================

# 依赖目录
node_modules/

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 运行时数据
.pnpm-store/
npm/
.yarn/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# 包管理器的 lock 文件
# 注：通常建议提交这些文件以确保依赖一致性，但这里提供忽略选项
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# 构建输出
dist/
build/
out/
.next/
.nuxt/
.gatsby/

# 测试覆盖率
coverage/
.nyc_output/

# 环境变量
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE/编辑器
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# =============================
# Rust 特定忽略项
# =============================

# 编译输出
target/
**/*.rs.bk

# Cargo 构建输出
Cargo.lock  # 注：通常建议提交，但这里提供忽略选项
*.d

# 可执行文件
**/*.exe
**/*.dll
**/*.so
**/*.dylib

# 测试和基准测试输出
**/*.profdata

# 调试符号
**/*.pdb
**/*.dSYM/

# Rust 分析文件
*.gcno
*.gcda

# =============================
# 通用开发环境忽略项
# =============================

# 编辑器/IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# 系统文件
*.log
*.tmp
*.temp

# 临时文件
*.swp
*.swo
*~
\#*#
.#*

# =============================
# 项目特定文件
# =============================

# 项目配置文件（按需取消注释）
# .envrc
# .project
# .settings/

# 文档
_site/
.sass-cache/
.jekyll-cache/

# 包输出
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip